# Copia este archivo como `.env` y completa los valores.
# Los encuentras en Supabase → Settings → API
VITE_SUPABASE_URL=https://prhbgniwymaaevnisyov.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# Dominio público de la app. Se usa como base de los enlaces del correo de
# restablecimiento de contraseña, para que apunten a producción aunque el reset
# se dispare desde localhost. Si se deja vacío, se usa window.location.origin.
# También es la base de la página de pago (/pay) que abre el APK.
VITE_PUBLIC_SITE_URL=https://multiclasificados-effe.vercel.app

# ─── Pasarela de pagos Izipay/Lyra (micuentaweb.pe) ───────────────────────────
# Estas dos son PÚBLICAS (van en el bundle). Las llaves SECRETAS (Shop ID,
# password, HMAC) NO van aquí: se cargan como secrets de Supabase Edge Functions
# (ver supabase/functions/create-payment/DEPLOY.md y payment-webhook/DEPLOY.md).
# La clave pública se obtiene en el Back Office → Configuración › Tienda › Claves
# de API REST (formato "ShopID:testpublickey_..." en TEST, "...:publickey_..." en prod).
VITE_IZIPAY_PUBLIC_KEY=
VITE_IZIPAY_STATIC_ENDPOINT=https://static.micuentaweb.pe
